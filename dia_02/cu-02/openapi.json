xt_endpoint":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Next Endpoint","description":"Endpoint tipado al que el agente debe llamar después de NORMALIZE"}},"type":"object","required":["status","service","message"],"title":"FromHandoffResponse"},"FunctionsEstimateRequest":{"properties":{"region":{"type":"string","title":"Region","description":"Región de Azure en formato armRegionName.","default":"eastus","examples":["eastus","westeurope","brazilsouth"]},"monthly_executions":{"type":"integer","exclusiveMinimum":0.0,"title":"Monthly Executions","description":"Número total de invocaciones por mes.","examples":[1000000,5000000,50000000]},"avg_duration_ms":{"type":"integer","exclusiveMinimum":0.0,"title":"Avg Duration Ms","description":"Duración promedio de cada ejecución en milisegundos.","examples":[200,500,1000]},"memory_mb":{"type":"integer","exclusiveMinimum":0.0,"title":"Memory Mb","description":"Memoria asignada en MB. Azure factura en bloques de 128MB.","default":128,"examples":[128,256,512,1024]},"currency":{"type":"string","title":"Currency","default":"USD","examples":["USD","EUR"]},"assumptions":{"items":{"$ref":"#/components/schemas/Assumption"},"type":"array","title":"Assumptions","description":"Assumptions que el agente quiere propagar al response. Permite que NORMALIZE del agente registre cómo derivó cada input desde el deep dive."}},"type":"object","required":["monthly_executions","avg_duration_ms"],"title":"FunctionsEstimateRequest"},"HTTPValidationError":{"properties":{"detail":{"items":{"$ref":"#/components/schemas/ValidationError"},"type":"array","title":"Detail"}},"type":"object","title":"HTTPValidationError"},"HandoffBack":{"properties":{"from_agent":{"type":"string","title":"From Agent","default":"cu-02-cost-estimator"},"status":{"type":"string","title":"Status","description":"completed | skipped | error | unsupported_service"},"service":{"type":"string","title":"Service"},"estimated_monthly_usd":{"anyOf":[{"type":"object"},{"type":"null"}